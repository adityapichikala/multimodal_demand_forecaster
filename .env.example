# ───────────────────────────────────────────────────────────────────
# Multimodal Demand Forecaster - Environment Variables
# ───────────────────────────────────────────────────────────────────

# 🔴 CRITICAL: SECRET_KEY must be set for JWT authentication!
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_string_here

# Database Configuration (PostgreSQL recommended, defaults to SQLite if not set)
DATABASE_URL=postgresql://postgres:12345678@localhost:5432/antigravity_db

# Redis Configuration (Used for Celery worker and FastAPI caching)
REDIS_URL=redis://localhost:6379/0

# API Keys for External Services
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
WEATHERAPI_KEY=your_weatherapi_key_here
NEWSAPI_AI_KEY=your_newsapi_ai_key_here

# Frontend URL (For CORS configuration)
FRONTEND_URL=http://localhost:3000
